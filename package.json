{
  "name": "claude-gatekeeper",
  "version": "1.0.0",
  "description": "Claude Code hook that uses AI to auto-approve safe permission requests",
  "main": "dist/index.js",
  "bin": {
    "claude-gatekeeper": "./bin/gatekeeper"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest tests/e2e/live.test.ts --no-coverage --testPathIgnorePatterns='[]'",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
